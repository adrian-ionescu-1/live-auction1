# Copy this file to ".env.local" and fill in your Supabase project credentials.
#
# Where to find them:
#   Supabase dashboard -> your project -> Project Settings -> API
#     - "Project URL"        -> NEXT_PUBLIC_SUPABASE_URL
#     - "anon public" key    -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Alternatively, copy the exact same values from your deployed Vercel project:
#   Vercel -> your project -> Settings -> Environment Variables
#
# Note: these are PUBLIC client keys (NEXT_PUBLIC_*), safe to expose in the
# browser. ".env.local" is gitignored and must never be committed.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Wargaming WoT Blitz application id, used SERVER-SIDE only to validate players
# and read their stats for community events (the /api/blitz/* routes). It is NOT
# a NEXT_PUBLIC_ var, so it never reaches the browser. Get a free one at:
#   https://developers.wargaming.net  ->  create an application (type: Blitz)
# Without it, Blitz-region events can't search/validate players.
WG_APPLICATION_ID=

# Contact form email delivery, via Resend (https://resend.com), SERVER-SIDE only.
# Setup:
#   1. Create a Resend account with the inbox you want to receive messages at
#      (e.g. theadrianone.dev@gmail.com).
#   2. API Keys -> create one -> paste it below as RESEND_API_KEY.
#   3. In test mode (no verified domain) Resend only delivers FROM
#      "onboarding@resend.dev" and only TO the account owner's email — which is
#      exactly our case, so it works out of the box.
#   4. To send from your own domain later, verify it in Resend -> Domains and set
#      CONTACT_FROM to e.g. "Auction App <contact@yourdomain.com>".
# CONTACT_TO defaults to theadrianone.dev@gmail.com; CONTACT_FROM defaults to
# "Auction App <onboarding@resend.dev>".
RESEND_API_KEY=
CONTACT_TO=
CONTACT_FROM=
